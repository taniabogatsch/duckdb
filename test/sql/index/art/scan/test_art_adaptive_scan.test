# name: test/sql/index/art/scan/test_art_adaptive_scan.test
# description: Test scanning more than standard vector size rows with an index scan.
# group: [scan]

statement ok
PRAGMA enable_verification

statement ok
CREATE TABLE integers(i INTEGER);

statement ok
INSERT INTO integers SELECT range FROM range(500000);

statement ok
INSERT INTO integers SELECT 42424242 FROM range(4000);

statement ok
CREATE INDEX i_index ON integers(i);

statement ok
PRAGMA explain_output='optimized_only'

# Verify that the plan contains an index scan.

query II
EXPLAIN SELECT * FROM integers WHERE i = 42424242;
----
logical_opt	<REGEX>:.*INDEX_SCAN.*
