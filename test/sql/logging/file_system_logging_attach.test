# name: test/sql/logging/file_system_logging_attach.test
# group: [logging]

require parquet

require json

require noforcestorage

require no_alternative_verify

statement ok
set enable_logging=true;

statement ok
set logging_level='trace';

statement ok
attach '__TEST_DIR__/filehandle_logging.db' as db;

statement ok
CREATE TABLE db.test AS SELECT 1;

statement ok
DETACH db;

query IIIII
SELECT scope, type, log_level, (message::JSON).fs, (message::JSON).op
FROM duckdb_logs
WHERE type = 'FileSystem'
ORDER BY timestamp
